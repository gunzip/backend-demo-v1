{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "client",
  "projectType": "application",
  "sourceRoot": "apps/client/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/client"],
      "options": {
        "command": "pnpm exec tsup --config apps/client/tsup.config.ts"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx apps/client/src/main.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint --fix apps/client/src apps/client/tsup.config.ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --passWithNoTests --dir apps/client/src"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsc --noEmit -p apps/client/tsconfig.json"
      }
    }
  }
}
