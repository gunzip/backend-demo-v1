{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "api",
  "projectType": "application",
  "sourceRoot": "apps/code-first/api/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/code-first/api"],
      "options": {
        "command": "pnpm exec tsup --config apps/code-first/api/tsup.config.ts"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx apps/code-first/api/src/api.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec eslint --fix apps/code-first/api/src apps/code-first/api/vitest.config.ts apps/code-first/api/tsup.config.ts"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config apps/code-first/api/vitest.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsc --noEmit -p apps/code-first/api/tsconfig.json"
      }
    }
  }
}
